# Copy to .env and adjust for local/production deployment.

POSTGRES_DB=codenames
POSTGRES_USER=codenames
POSTGRES_PASSWORD=codenames

DATABASE_URL=jdbc:postgresql://localhost:5432/codenames
DATABASE_USER=codenames
DATABASE_PASSWORD=codenames
DATABASE_DRIVER=org.postgresql.Driver

# At least 32 random characters
SESSION_SECRET=replace-with-long-random-secret

# Public URL (https:// when TLS is enabled)
APP_PUBLIC_URL=https://example.com
APP_SECURE_COOKIES=true

# TLS keystore (PKCS12) for application-prod-https.yaml
# Generate: SSL_KEYSTORE_PASSWORD=secret ./scripts/pem-to-pkcs12.sh
# Or dev:    SSL_KEYSTORE_PASSWORD=secret ./scripts/generate-dev-certs.sh
SSL_CERTS_DIR=./certs
SSL_KEYSTORE_PASSWORD=
SSL_PRIVATE_KEY_PASSWORD=
HTTP_PORT=8080
HTTPS_PORT=443

# Production deploy (docker-compose.prod.yml; CI sets IMAGE_TAG on tag push)
# IMAGE_NAME and IMAGE_TAG must also be in GitHub secret DEPLOY_DOTENV on the server.
# IMAGE_NAME=your-dockerhub-user/codenames
# IMAGE_TAG=v1.0.0

# Umami analytics (self-hosted; optional for local dev)
UMAMI_APP_SECRET=replace-with-long-random-secret
UMAMI_DB_NAME=umami
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=umami
UMAMI_PORT=3000
# Public URL of Umami (subdomain recommended), e.g. https://analytics.example.com
UMAMI_PUBLIC_URL=https://analytics.example.com
# Baked into frontend at build time (from Umami dashboard → Settings → Websites)
VITE_UMAMI_SCRIPT_URL=https://analytics.example.com/script.js
VITE_UMAMI_WEBSITE_ID=
