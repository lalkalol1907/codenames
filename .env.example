# Copy to .env and adjust for local/production deployment.

POSTGRES_DB=codenames
POSTGRES_USER=codenames
POSTGRES_PASSWORD=codenames

DATABASE_URL=jdbc:postgresql://localhost:5432/codenames
DATABASE_USER=codenames
DATABASE_PASSWORD=codenames
DATABASE_DRIVER=org.postgresql.Driver

# At least 32 random characters
SESSION_SECRET=replace-with-long-random-secret

# Redis (required in prod; app.scaling.redis-enabled=true in application-prod.yaml)
# REDIS_PASSWORD is optional — omit or leave blank to disable auth
REDIS_PASSWORD=replace-with-redis-password

# Public domain used by Caddy for auto-TLS (Let's Encrypt).
# DNS A/AAAA must point to this host; ports 80 and 443 must be open.
APP_DOMAIN=game.example.com

# Optional: email for Let's Encrypt expiry notifications
ACME_EMAIL=admin@example.com

# Derived from APP_DOMAIN — used by the Spring app for redirects / cookie domain
APP_PUBLIC_URL=https://game.example.com
APP_SECURE_COOKIES=true

# Production deploy (docker-compose.prod.yml; CI sets IMAGE_TAG on tag push)
# GitHub secret DEPLOY_DOTENV: copy this file minus local-only vars.
# IMAGE_NAME=your-dockerhub-user/codenames
# IMAGE_TAG=v1.0.0

# Umami analytics (self-hosted; routed via Caddy subdomain in prod)
UMAMI_APP_SECRET=replace-with-long-random-secret
UMAMI_DB_NAME=umami
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=umami
# Subdomain for Umami — Caddy will obtain a TLS cert for it automatically.
# DNS A/AAAA must point to the same host as APP_DOMAIN.
ANALYTICS_DOMAIN=analytics.example.com
# Baked into frontend at build time (from Umami dashboard → Settings → Websites)
VITE_UMAMI_SCRIPT_URL=https://analytics.example.com/script.js
VITE_UMAMI_WEBSITE_ID=
