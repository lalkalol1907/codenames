{
  "name": "codeword-frontend",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "prebuild": "node scripts/sync-i18n.mjs",
    "dev": "vite",
    "build": "vite-ssg build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@discord/embedded-app-sdk": "^2.5.0",
    "@unhead/vue": "^2.0.12",
    "pinia": "^3.0.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^25.9.2",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.5.0",
    "globals": "^16.5.0",
    "happy-dom": "^20.0.10",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^6.3.5",
    "vite-ssg": "^28.0.0",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^2.2.8"
  }
}
